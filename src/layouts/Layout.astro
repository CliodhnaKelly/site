---
import '../styles/global.css';
import SparkleLayer from '../components/SparkleLayer.astro';
import VisitorCounter from '../components/VisitorCounter.astro';

interface Props {
	title?: string;
}

const { title = 'Cliodhna | Retro Portfolio' } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Press+Start+2P&family=Fredoka+One&display=swap"
			rel="stylesheet"
		/>
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<SparkleLayer />
		<div class="site-shell">
			<header class="site-header">
				<div class="bebo-topbar">
					<a class="clio-logo" href="/" aria-label="Clio home"><span>c</span>lio</a>
					<nav class="bebo-tabs" aria-label="Site sections">
						<a href="/">Home</a>
						<a href="/profile">Profile</a>
						<a href="/photos">Photos</a>
						<a href="/blog">Blog</a>
					</nav>
					<VisitorCounter />
				</div>
			</header>
			<div class="site-container">
				<slot />
			</div>
			<footer class="site-footer">
				<p class="heading-font">Best viewed with glitter mode enabled</p>
			</footer>
		</div>
	</body>
</html>
